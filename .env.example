# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=orders

# Lake storage (MinIO locally / S3 in prod)
LAKE_ROOT=s3a://lakehouse
CHECKPOINT_ROOT=s3a://lakehouse/_checkpoints
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Snowflake (serving layer, used by dbt + external tables)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Alerting
SLACK_WEBHOOK_URL=
